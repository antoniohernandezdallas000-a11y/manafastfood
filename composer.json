{
    "name": "mana/fast-food",
    "description": "Maná Fast Food - Sistema de pedidos online",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "classmap": [
            "backend/models/",
            "backend/helpers/",
            "backend/middleware/",
            "backend/config/"
        ],
        "files": [
            "backend/config/database.php",
            "backend/config/cors.php",
            "backend/helpers/jwt.php",
            "backend/middleware/AuthMiddleware.php"
        ]
    },
    "scripts": {
        "test": "vendor/bin/phpunit --configuration tests/phpunit.xml",
        "test:unit": "vendor/bin/phpunit --configuration tests/phpunit.xml --testsuite Unit",
        "test:integration": "vendor/bin/phpunit --configuration tests/phpunit.xml --testsuite Integration",
        "coverage": "vendor/bin/phpunit --configuration tests/phpunit.xml --coverage-html tests/coverage"
    }
}
