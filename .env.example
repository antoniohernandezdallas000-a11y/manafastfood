# ============================================
# MANÁ FAST FOOD - VARIABLES DE ENTORNO
# ============================================
# Copia este archivo como .env y completa los valores

# --- BASE DE DATOS ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mana_fast_food
DB_USER=root
DB_PASSWORD=

# --- JWT (autenticación) ---
JWT_SECRET=changeme_to_a_random_secret_key
JWT_EXPIRY=24h

# --- TASA BCV ---
# 'automatica' usa la API de BCV, 'manual' usa TASA_BCV_MANUAL
TASA_BCV_MODO=automatica
TASA_BCV_MANUAL=62.45
BCV_API_URL=https://api.bcv.com.ve/tasas

# --- PAGOMÓVIL (cuentas del comercio) ---
# Se gestionan desde el panel admin
# Cuenta activa por defecto (sobrescribe la BD si está configurada)
PAGOMOVIL_BANCO=Mercantil
PAGOMOVIL_TITULAR=Maná Fast Food
PAGOMOVIL_TELEFONO=04141234567
PAGOMOVIL_CEDULA=J-12345678-9

# --- WHATSAPP ---
WHATSAPP_NUMBER=584140000000
WHATSAPP_MESSAGE_TEMPLATE=¡Hola! Quiero confirmar mi pedido %pedido% de Maná Fast Food.

# --- GOOGLE MAPS ---
GOOGLE_MAPS_API_KEY=tu_api_key_aqui

# --- UPLOADS ---
UPLOAD_MAX_SIZE=5MB
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png
UPLOAD_PATH=../backend/uploads/captures

# --- URL DEL SITIO ---
SITE_URL=http://localhost:8000
SITE_NAME=Maná Fast Food

# --- STRIPE (internacional) ---
# Solo si usas checkout internacional
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# --- STRIPE PRECIOS (ID de precios en Stripe) ---
# STRIPE_PRICE_MANA_BURGER=price_xxxxx
# STRIPE_PRICE_MANA_DOBLE=price_xxxxx

# --- PASARELA VENEZOLANA C2P ---
# Configuración para PagoMóvil C2P
# BANK_API_URL=https://api.banco.com.ve/v1/pagos
# BANK_API_KEY=tu_api_key_aqui
# MERCHANT_ID=MANA001
# MERCHANT_PHONE=04141234567
# MERCHANT_CEDULA=J-12345678-9
# MERCHANT_BANK_CODE=0105
